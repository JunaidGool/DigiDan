# Contact form — Formspree endpoint (https://formspree.io/f/xxxxxxx).
# Copy to .env.local and set before the form can submit in production.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Privacy-friendly analytics (Plausible). Set to the production domain, e.g.
# digidan.co.za. Leave empty to disable analytics entirely (no script loads).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
